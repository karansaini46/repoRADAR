# ==========================================
# AutoScan Revenue Engine Configuration
# ==========================================

# ------------------------------------------
# Infrastructure Services
# ------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/autoscan
REDIS_URL=redis://redis:6379/0

# ------------------------------------------
# Application Core
# ------------------------------------------
APP_URL=http://localhost:3000
LOG_LEVEL=INFO
REPORT_SIGNING_SECRET=your_super_secret_signing_key_here

# ------------------------------------------
# External APIs
# ------------------------------------------
# GitHub (For repository discovery and cloning)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Anthropic / AI (For vulnerability verification and summarization)
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key

# Enrichment Providers (For company/contact sourcing)
HUNTER_API_KEY=your_hunter_io_api_key
CLEARBIT_API_KEY=sk_your_clearbit_api_key

# Communications (Outreach)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ------------------------------------------
# Alerting & Monitoring
# ------------------------------------------
# Slack incoming webhook URL for critical alerts
SLACK_WEBHOOK_URL=https://example.com/webhook/slack

# Email address to receive system health and degraded pipeline alerts
ALERT_EMAIL=admin@yourdomain.com
